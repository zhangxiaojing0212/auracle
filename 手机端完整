<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<title>Auracle</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Bellefair&family=Gabarito:wght@400;500&family=Noto+Sans+JP:wght@300&display=swap" rel="stylesheet">
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0;-webkit-tap-highlight-color:transparent}
html,body{height:100%;width:100%;overflow:hidden;background:#0d0d0d}

:root{
  --bg:#1f1f1f;
  --bg2:#141414;
  --cream:#fffbf2;
  --cream2:#fffaef;
  --sage:#778366;
  --sage2:#bbc4a9;
  --sage3:#9ba48f;
  --rose:#aa8787;
  --rose2:#d1b6c6;
  --warm:#f6f4f1;
  --brown:#472c12;
  --muted:rgba(208,194,194,0.65);
  --muted2:rgba(255,255,255,0.3);
  --border:#7a766d;
  --nav-h:62px;
  --header-h:56px;
  --ff-serif:'Bellefair',serif;
  --ff-sans:'Gabarito',sans-serif;
  --ff-jp:'Noto Sans JP',sans-serif;
}

#app{
  width:100%;
  max-width:430px;
  height:100vh;
  margin:0 auto;
  position:relative;
  background:var(--bg);
  overflow:hidden;
  display:flex;
  flex-direction:column;
}

/* ── Pages ── */
.page{
  position:absolute;
  inset:0;
  display:flex;
  flex-direction:column;
  opacity:0;
  pointer-events:none;
  transition:opacity .3s ease;
  overflow:hidden;
}
.page.active{
  opacity:1;
  pointer-events:auto;
}

/* ── Header ── */
.header{
  position:absolute;
  top:0;left:0;right:0;
  height:var(--header-h);
  display:flex;
  align-items:center;
  justify-content:space-between;
  padding:0 20px;
  z-index:10;
  background:linear-gradient(to bottom,rgba(31,31,31,.95),transparent);
}
.logo{
  font-family:var(--ff-serif);
  font-size:20px;
  color:#fff;
  letter-spacing:2px;
}
.menu-btn{
  background:none;border:none;cursor:pointer;
  display:flex;flex-direction:column;gap:5px;
  padding:8px;
}
.menu-btn span{
  display:block;height:1px;background:rgba(255,255,255,.7);
  transition:width .2s;
}
.menu-btn span:nth-child(1){width:22px}
.menu-btn span:nth-child(2){width:22px}
.menu-btn span:nth-child(3){width:14px}

/* ── Bottom Nav ── */
.nav-bar{
  position:absolute;
  bottom:0;left:0;right:0;
  height:var(--nav-h);
  background:var(--bg2);
  border-top:1px solid rgba(122,118,109,.25);
  display:flex;
  align-items:flex-start;
  justify-content:space-between;
  padding:10px 16px 0;
  z-index:10;
}
.nav-btn{
  background:none;border:none;cursor:pointer;
  display:flex;flex-direction:column;align-items:center;gap:4px;
  padding:4px 8px;
  flex:1;
  transition:opacity .2s;
}
.nav-btn svg{width:20px;height:20px;stroke-width:1.5}
.nav-btn span{
  font-family:var(--ff-serif);
  font-size:9px;
  letter-spacing:.4px;
  color:var(--muted2);
  white-space:nowrap;
}
.nav-btn.active svg{stroke:rgba(255,255,255,.92)}
.nav-btn.active span{color:rgba(255,255,255,.92)}
.nav-btn:not(.active) svg{stroke:rgba(255,255,255,.3)}

/* ── Scrollable body area ── */
.page-body{
  flex:1;
  overflow-y:auto;
  overflow-x:hidden;
  -webkit-overflow-scrolling:touch;
  padding-top:var(--header-h);
  padding-bottom:calc(var(--nav-h) + 8px);
}
.page-body::-webkit-scrollbar{display:none}

/* ───────────────────────────
   PAGE 1: SPLASH
──────────────────────────── */
#page-splash{background:var(--bg)}
.splash-bg{
  position:absolute;inset:0;
  background-color:#1a1917;
}
.splash-grad{
  position:absolute;bottom:0;left:0;right:0;height:45%;
  background:linear-gradient(to bottom,transparent,rgba(20,19,17,.95));
}
.splash-content{
  position:absolute;inset:0;
  display:flex;flex-direction:column;
  align-items:center;justify-content:space-between;
  padding:52px 24px 80px;
}
.splash-top{
  display:flex;align-items:center;gap:6px;
  font-family:var(--ff-serif);
  font-size:11px;letter-spacing:3px;
  color:rgba(208,194,194,.75);
  text-transform:uppercase;
}
.tick-marks{display:flex;align-items:center;gap:6px}
.tick-marks span{width:2px;background:rgba(208,194,194,.4);display:block}
.tick-marks span:nth-child(1){height:14px;opacity:.4}
.tick-marks span:nth-child(2){height:14px;opacity:.55}
.tick-marks span:nth-child(3){height:14px;opacity:.7}

.splash-img-wrap{
  position:relative;
  width:272px;height:272px;
  margin-top:20px;
}
.splash-img-outer{
  position:absolute;inset:0;
  border:1px dashed rgba(208,194,194,.25);
}
.splash-img-inner{
  position:absolute;inset:6px;
  border:1.5px solid rgba(208,194,194,.55);
  overflow:hidden;
}
.splash-img-inner img{
  width:100%;height:100%;object-fit:cover;
}
.corner{position:absolute;width:14px;height:14px}
.corner.tl{top:0;left:0;border-top:1.5px solid rgba(208,194,194,.7);border-left:1.5px solid rgba(208,194,194,.7)}
.corner.tr{top:0;right:0;border-top:1.5px solid rgba(208,194,194,.7);border-right:1.5px solid rgba(208,194,194,.7)}
.corner.bl{bottom:0;left:0;border-bottom:1.5px solid rgba(208,194,194,.7);border-left:1.5px solid rgba(208,194,194,.7)}
.corner.br{bottom:0;right:0;border-bottom:1.5px solid rgba(208,194,194,.7);border-right:1.5px solid rgba(208,194,194,.7)}

.ornament-divider{
  width:320px;
  display:flex;align-items:center;gap:10px;
  margin:12px 0;
}
.ornament-divider .line{
  flex:1;height:1px;
  background:linear-gradient(to right,transparent,rgba(208,194,194,.6));
}
.ornament-divider .line.rev{
  background:linear-gradient(to left,transparent,rgba(208,194,194,.6));
}
.ornament-divider .diamond{
  font-size:10px;color:rgba(208,194,194,.6);
}

.splash-text{text-align:center}
.splash-title{
  font-family:var(--ff-serif);
  font-size:42px;line-height:1.15;
  color:var(--warm);
  letter-spacing:1px;
}
.splash-sub{
  font-family:var(--ff-serif);
  font-size:13px;line-height:1.8;
  color:rgba(208,194,194,.65);
  letter-spacing:1.6px;
  margin-top:8px;
}

.splash-cta-wrap{text-align:center}
.splash-cta{
  position:relative;
  display:inline-block;
  padding:0 32px;
  height:52px;line-height:52px;
  font-family:var(--ff-serif);
  font-size:16px;letter-spacing:3.5px;
  text-transform:uppercase;
  color:var(--warm);
  background:rgba(246,244,241,.08);
  border:1px solid rgba(208,194,194,.7);
  cursor:pointer;
  min-width:200px;
  transition:background .2s;
}
.splash-cta::after{
  content:'';
  position:absolute;
  bottom:-5px;right:-5px;
  width:100%;height:100%;
  border:1px solid rgba(208,194,194,.3);
  pointer-events:none;
}
.splash-cta:active{background:rgba(246,244,241,.18)}
.splash-journey{
  font-family:var(--ff-serif);
  font-size:10px;letter-spacing:3px;
  color:rgba(208,194,194,.4);
  text-transform:uppercase;
  margin-top:10px;
}

/* ───────────────────────────
   PAGE 2: HOME (Chapters)
──────────────────────────── */
#page-home .page-bg{
  position:absolute;inset:0;pointer-events:none;
  background-image:url('https://www.figma.com/api/mcp/asset/133a4355-f1ec-493f-a965-93aac3838e0b');
  background-size:cover;background-position:center;
  opacity:.35;
}
.home-banner{
  position:absolute;
  top:var(--header-h);left:0;right:0;
  height:72px;overflow:hidden;
}
.home-banner img{width:100%;height:100%;object-fit:cover;opacity:.7}
.home-banner::before,.home-banner::after{
  content:'';position:absolute;left:0;right:0;height:28px;z-index:1;
}
.home-banner::before{top:0;background:linear-gradient(var(--bg),transparent)}
.home-banner::after{bottom:0;background:linear-gradient(transparent,var(--bg))}

.section-label{
  display:flex;align-items:center;justify-content:space-between;
  padding:0 20px;margin-bottom:12px;
}
.section-label span:first-child{
  font-family:var(--ff-serif);font-size:10px;
  letter-spacing:2.2px;text-transform:uppercase;
  color:rgba(255,255,255,.4);
}
.section-label span:last-child{
  font-family:var(--ff-serif);font-size:10px;
  color:rgba(255,255,255,.2);letter-spacing:1px;
}

.chapter-list{
  display:flex;flex-direction:column;gap:12px;
  padding:0 20px;
}

.chapter-card{
  position:relative;
  border:2.5px solid var(--border);
  padding:7px;
  cursor:pointer;
  transition:transform .15s;
  overflow:hidden;
}
.chapter-card:active{transform:scale(.98)}

.chapter-card-bg{
  position:absolute;inset:0;
  background-size:cover;background-position:center;
  opacity:.9;
}
.chapter-card.c1 .chapter-card-bg{background-color:#bbc4a9}
.chapter-card.c2 .chapter-card-bg{background-color:#fffbf2}
.chapter-card.c3 .chapter-card-bg{background-color:#ebd5d5}

.chapter-card-inner{
  position:relative;
  border:1px solid var(--border);
  padding:14px;min-height:160px;
  display:flex;flex-direction:column;justify-content:space-between;
}
.chapter-num{
  position:absolute;right:12px;bottom:8px;
  font-family:var(--ff-serif);font-size:60px;
  color:rgba(26,26,26,.1);line-height:1;
  pointer-events:none;
}
.chapter-label{
  font-family:var(--ff-serif);font-size:10px;
  letter-spacing:.3px;color:rgba(42,42,42,.65);
}
.chapter-title{
  font-family:var(--ff-serif);font-size:18px;
  line-height:1.35;color:#1a1a1a;
  margin:20px 0 6px;
}
.chapter-sub{
  font-family:var(--ff-serif);font-size:11px;
  color:rgba(42,42,42,.6);
}
.chapter-link{
  font-family:var(--ff-serif);font-size:12px;
  color:#1a1a1a;text-decoration:underline;
  margin-top:auto;padding-top:18px;
  display:inline-block;
}

/* ───────────────────────────
   PAGE 3: DAILY CHECK-IN
──────────────────────────── */
#page-checkin{background:#0d0d0d}
#page-checkin .page-bg{
  position:absolute;inset:0;pointer-events:none;
  background-image:url('https://www.figma.com/api/mcp/asset/133a4355-f1ec-493f-a965-93aac3838e0b');
  background-size:cover;background-position:center;
  opacity:.72;
}

.daily-card-wrap{
  padding:12px 20px 20px;
  display:flex;justify-content:center;
}
.daily-card{
  background:var(--cream2);
  border:1.5px solid #5a3a1a;
  width:100%;max-width:340px;
  position:relative;
}
.daily-card-inner{
  border:.8px solid #7a5a2a;
  margin:3px;
  padding:24px 28px 32px;
  display:flex;flex-direction:column;align-items:center;gap:0;
}
.daily-divider{
  width:88%;height:1px;
  background:rgba(150,120,80,.35);
  margin:18px 0;
}
.daily-date{
  font-family:var(--ff-serif);font-size:22px;
  color:#aa5a4a;letter-spacing:1.2px;
  text-align:center;margin-bottom:6px;
}
.daily-ganzhi{
  font-family:var(--ff-jp);font-weight:300;
  font-size:14px;line-height:2;letter-spacing:.8px;
  color:#3a2a1a;text-align:center;
}
.daily-headline{
  font-family:var(--ff-serif);font-size:22px;
  line-height:1.4;text-align:center;
  color:#6a7a5a;letter-spacing:.5px;
}
.daily-body{
  font-family:var(--ff-serif);font-size:15px;
  line-height:1.8;text-align:center;
  color:#aa6a6a;margin-top:10px;
}
.daily-stamp-wrap{
  display:flex;justify-content:center;
  margin:14px 0;
}
.daily-stamp{
  border:1.5px solid #3a2008;
  width:96px;height:96px;
  display:flex;align-items:center;justify-content:center;
}
.daily-stamp span{
  font-size:76px;color:#3a2008;
  font-family:'Noto Serif SC',var(--ff-serif);
  line-height:1;
}
.daily-yi-ji{
  display:flex;flex-direction:column;gap:18px;
  width:100%;
}
.yi-ji-item{display:flex;flex-direction:column;align-items:center;gap:3px}
.yi-ji-label{
  font-family:var(--ff-jp);font-size:13px;
  color:#5a4a3a;letter-spacing:1.2px;
}
.yi-ji-label b{font-family:var(--ff-serif);font-weight:400;letter-spacing:.6px}
.yi-ji-value{
  font-family:var(--ff-serif);font-size:26px;
  letter-spacing:.8px;color:#3a2a1a;
}
.yi-ji-item.yi .yi-ji-value{color:#aa5a5a}
.yi-ji-item.ji .yi-ji-value{color:#6a7a5a}

/* ───────────────────────────
   PAGE 4: LIFE SCRIPT (Test)
──────────────────────────── */
#page-test .page-bg{
  position:absolute;inset:0;pointer-events:none;
  background-image:url('https://www.figma.com/api/mcp/asset/133a4355-f1ec-493f-a965-93aac3838e0b');
  background-size:cover;background-position:center;
  opacity:.2;
}
#page-test .page-body{
  padding-top:var(--header-h);
}
#test-chapters{
  padding-top:48px;
}
.test-ornament{
  width:354px;
  max-width:calc(100% - 48px);
  height:62px;
  margin:0 auto 25px;
  background:url('data:image/webp;base64,') center/100% 100% no-repeat;
}
#page-test .section-label{
  padding:0 20px;
  margin-bottom:14px;
}
#page-test .chapter-list{
  gap:12px;
  padding:0 13px;
}
#page-test .chapter-card{
  border:0;
  padding:0;
  aspect-ratio:404/218;
  background-size:100% 100%;
  background-position:center;
  background-repeat:no-repeat;
}
#page-test .chapter-card.c1{background-image:url('data:image/webp;base64,')}
#page-test .chapter-card.c2{background-image:url('data:image/webp;base64,')}
#page-test .chapter-card.c3{
  aspect-ratio:404/215;
  background-image:url('data:image/webp;base64,');
}
#page-test .chapter-card-bg,
#page-test .chapter-card-inner{
  display:none;
}

.form-card{
  background:var(--cream);
  border:1.5px solid rgba(246,244,241,.8);
  box-shadow:5px 5px 5px rgba(120,114,114,.35);
  margin:0 16px;
  position:relative;
}
.form-card-inner{
  border:.8px solid rgba(246,244,241,.5);
  margin:3px;padding:24px 20px 28px;
}
.form-title{
  font-family:var(--ff-serif);font-size:28px;
  color:var(--sage);letter-spacing:.8px;
  text-align:center;margin-bottom:20px;
}
.close-btn{
  position:absolute;top:8px;right:16px;
  font-family:'Gentium Book Basic',var(--ff-serif);
  font-size:32px;color:var(--sage3);
  background:none;border:none;cursor:pointer;line-height:1;
}

.gender-row{
  display:flex;gap:10px;justify-content:center;
  margin-bottom:18px;
}
.gender-btn{
  background:var(--sage2);
  border:none;
  border-radius:8px;
  padding:12px 20px;
  font-family:var(--ff-serif);font-size:18px;
  color:#fff;cursor:pointer;
  display:flex;align-items:center;gap:8px;
  box-shadow:inset -3px -3px 4px rgba(0,0,0,.25);
  transition:opacity .2s;
}
.gender-btn:not(.selected){opacity:.7}
.gender-btn.selected{opacity:1}

.form-field{
  margin-bottom:16px;
  border-bottom:1px solid var(--sage2);
  padding-bottom:6px;
}
.form-field label{
  font-family:var(--ff-serif);font-size:16px;
  color:var(--sage2);display:block;
}
.form-field input{
  width:100%;background:none;border:none;outline:none;
  font-family:var(--ff-serif);font-size:16px;
  color:var(--brown);padding-top:4px;
}
.form-field input::placeholder{color:var(--sage2)}

.field-row{display:flex;gap:16px}
.field-row .form-field{flex:1}

.place-field{
  position:relative;
  border:1px solid var(--sage2);border-radius:2px;
  padding:14px 16px;margin-bottom:18px;
  display:flex;align-items:center;justify-content:space-between;
}
.place-field span{font-family:var(--ff-serif);font-size:18px;color:var(--sage2)}
.place-field svg{stroke:var(--sage2);width:20px;height:20px}

.submit-btn{
  display:block;width:80%;margin:0 auto;
  padding:20px 0;
  background:var(--rose);
  border:none;cursor:pointer;
  font-family:var(--ff-serif);font-size:22px;
  letter-spacing:1px;color:#fff;
  text-align:center;
  box-shadow:inset -3px -4px 4px rgba(0,0,0,.25);
  transition:opacity .2s;
}
.submit-btn:active{opacity:.85}

/* ───────────────────────────
   PAGE 5: CALIBRATION (step form)
──────────────────────────── */
#page-calibration{background:#0d0d0d}
#page-calibration .page-bg{
  position:absolute;inset:0;pointer-events:none;
  background-image:url('https://www.figma.com/api/mcp/asset/133a4355-f1ec-493f-a965-93aac3838e0b');
  background-size:cover;background-position:center;
  opacity:.6;
}

/* 结果卡片外层 */
.result-card{
  margin:12px 16px 0;
  background:var(--cream2);
  border:1.5px solid #5a3a1a;
  position:relative;
  z-index:1;
}
.result-card-inner{
  border:.8px solid rgba(122,90,42,.35);
  margin:2px;
  padding:24px 20px 28px;
}
.rel-result-locked{
  overflow:hidden;
}
.rel-result-locked .result-card-inner{
  filter:blur(.6px);
}
.rel-soon-mask{
  position:absolute;
  inset:2px;
  z-index:3;
  display:flex;
  align-items:center;
  justify-content:center;
  background:rgba(245,240,230,.72);
  border:.8px solid rgba(122,90,42,.2);
  backdrop-filter:blur(1.5px);
  -webkit-backdrop-filter:blur(1.5px);
  pointer-events:auto;
}
.rel-soon-mask span{
  font-family:var(--ff-jp);
  font-size:18px;
  letter-spacing:5px;
  color:#3a2a1a;
}

/* 标题 */
.result-title{
  font-family:'Bellefair',serif;font-size:26px;
  color:#5a3a1a;text-align:center;
  font-style:italic;letter-spacing:.5px;
  margin-bottom:10px;
}
.result-title-rule{
  display:flex;align-items:center;justify-content:center;gap:8px;
  margin-bottom:20px;
}
.result-title-rule .line{width:60px;height:1px;background:rgba(122,90,42,.3)}
.result-title-rule .dot{width:5px;height:5px;border-radius:50%;background:rgba(122,90,42,.5)}

/* Section标题 */
.rs-label{
  font-family:var(--ff-serif);font-size:14px;
  color:#3a2a1a;letter-spacing:.3px;
  margin-bottom:12px;
}
.rs-divider{height:1px;background:rgba(122,90,42,.2);margin:18px 0}

/* 四柱矩阵 */
.pillar-grid{
  display:grid;grid-template-columns:repeat(4,1fr);gap:6px;
  margin-bottom:6px;
}
.pillar-cell{
  border:1px solid rgba(122,90,42,.4);
  padding:8px 4px 10px;
  text-align:center;background:rgba(255,251,242,.6);
}
.pillar-pos{
  font-family:var(--ff-jp);font-size:9px;
  color:rgba(90,58,26,.55);letter-spacing:1px;
  margin-bottom:6px;
}
.pillar-char{
  font-family:'Noto Serif SC',serif;font-size:32px;
  color:#2a1a0a;line-height:1;margin-bottom:6px;
}
.pillar-role{
  font-family:var(--ff-serif);font-size:9px;
  color:rgba(90,58,26,.6);letter-spacing:.3px;line-height:1.4;
}

/* 五行条 */
.element-bars{display:flex;flex-direction:column;gap:8px;margin-bottom:14px}
.element-row{display:flex;align-items:center;gap:8px}
.element-name{
  font-family:var(--ff-serif);font-size:12px;
  color:#3a2a1a;width:38px;flex-shrink:0;
}
.element-track{flex:1;height:8px;background:rgba(180,160,130,.2);border-radius:0}
.element-fill{height:100%;border-radius:0;background:#aa7a7a}

/* Inner Persona 双栏 */
.persona-grid{
  display:grid;grid-template-columns:1fr 1fr;
  border:1px solid rgba(122,90,42,.35);
  margin-bottom:12px;
}
.persona-col{padding:14px 12px}
.persona-col:first-child{border-right:1px solid rgba(122,90,42,.35)}
.persona-col-title{
  font-family:'Bellefair',serif;font-size:16px;
