      <svg viewBox="0 0 24 24" fill="none"><path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 01-8 0"/></svg>
      <span>Shop</span>
    </button>
    <button class="nav-btn" onclick="navTo('mine',this)" data-page="mine">
      <svg viewBox="0 0 24 24" fill="none"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
      <span>Mine</span>
    </button>
  </nav>
</div>

</div><!-- #app -->

<script>
const pageMap={
  splash:'page-splash',
  login:'page-login',
  home:'page-home',
  checkin:'page-checkin',
  test:'page-test',
  calibration:'page-calibration',
  relationship:'page-relationship',
  'relationship-input':'page-relationship-input',
  oracle:'page-oracle',
  'oracle-number':'page-oracle-number',
  'oracle-result':'page-oracle-result',
  mine:'page-mine',
  pricing:'page-pricing',
  shop:'page-shop',
  'shop-detail':'page-shop-detail'
};
let pageHistory=[];

function showPage(id){
  document.querySelectorAll('.page').forEach(p=>{
    p.classList.remove('active');
  });
  const el=document.getElementById(id);
  if(el){
    el.classList.add('active');
    const body=el.querySelector('.page-body');
    if(body)body.scrollTop=0;
  }
  // Test 하위 페이지들은 nav에서 Test를 active로 유지
  const testSubPages=['page-test','page-calibration','page-oracle','page-oracle-number','page-oracle-result','page-relationship'];
  const activeNav=id==='page-relationship-input'?'home':
    testSubPages.includes(id)?'test':
    id==='page-home'||id==='page-checkin'?'home':
    id==='page-shop'?'shop':
    id==='page-mine'?'mine':null;
  if(activeNav){
    document.querySelectorAll('.nav-btn').forEach(b=>{
      b.classList.toggle('active', b.dataset.page===activeNav);
    });
  }
}

function goTo(name){
  const cur=document.querySelector('.page.active');
  if(cur)pageHistory.push(cur.id);
  showPage(pageMap[name]||name);
}

function showTestForm(){
  document.getElementById('test-chapters').style.display='none';
  document.getElementById('test-form').style.display='block';
}
function hideTestForm(){
  document.getElementById('test-form').style.display='none';
  document.getElementById('test-chapters').style.display='block';
}
function goBack(){
  const prev=pageHistory.pop();
  if(prev)showPage(prev);
  else showPage('page-home');
}

function navTo(name,btn){
  const pageId=pageMap[name];
  const targetPage=document.getElementById(pageId);
  if(!targetPage)return;
  const allNavBtns=document.querySelectorAll('#'+targetPage.closest('.page')?.id+' .nav-btn, .page.active .nav-btn');
  const activePage=document.querySelector('.page.active');
  if(activePage){
    activePage.querySelectorAll('.nav-btn').forEach(b=>b.classList.remove('active'));
  }
  pageHistory=[];
  showPage(pageId);
  if(name==='home')showPage('page-home');
  else if(name==='test'){goTo('test');hideTestForm();}
  else if(name==='shop')goTo('shop');
  else if(name==='mine')goTo('mine');
}

function navCheckinTo(name,btn){
  pageHistory=[];
  const pageId=pageMap[name]||(name==='home'?'page-checkin':pageMap[name]);
  if(name==='home'){showPage('page-checkin');return;}
  showPage(pageMap[name]);
}

function selectGender(btn,g){
  document.querySelectorAll('#page-test .gender-btn').forEach(b=>b.classList.remove('selected'));
  btn.classList.add('selected');
}

function selectYear(btn){
  document.querySelectorAll('#yearGrid .year-btn').forEach(b=>b.classList.remove('selected'));
  btn.classList.add('selected');
  const sub=document.getElementById('calibSubmit');
  if(sub){sub.classList.add('ready')}
}

function selectRelTab(tab){
  document.querySelectorAll('#relTabs .rel-tab').forEach(t=>t.classList.remove('active'));
  tab.classList.add('active');
  const secLabel=document.getElementById('relSectionLabel');
  if(secLabel){
    const nameEl=tab.querySelector('.rel-tab-name');
    secLabel.textContent=nameEl?nameEl.textContent:tab.textContent;
  }
}

function selectShopTab(tab){
  document.querySelectorAll('.shop-tab').forEach(t=>t.classList.remove('active'));
  tab.classList.add('active');
}

function toggleMineSection(name){
  const section = document.getElementById('mine-'+name+'-section');
  const arrow = document.getElementById(name+'-arrow');
  if(!section) return;
  const isOpen = section.style.display !== 'none';
  section.style.display = isOpen ? 'none' : 'block';
  if(arrow) arrow.style.transform = isOpen ? '' : 'rotate(90deg)';
}
function copyInviteLink(){
  navigator.clipboard.writeText('auracle.ai/invite').catch(()=>{});
  const btn = event.target;
  const orig = btn.textContent;
  btn.textContent = 'Copied!';
  setTimeout(()=>{ btn.textContent = orig; }, 1500);
}

// ── 登录逻辑 ──
function doLogin(){
  goTo('home');
}

// ── 语言切换 ──
let currentLang = 'zh';
function setLang(lang){
  currentLang = lang;
  const zh = document.getElementById('lang-zh');
  const en = document.getElementById('lang-en');
  if(lang === 'zh'){
    zh.style.background = 'rgba(208,182,168,.18)';
    zh.style.color = 'rgba(208,182,168,.9)';
    en.style.background = 'none';
    en.style.color = 'rgba(208,182,168,.5)';
  } else {
    en.style.background = 'rgba(208,182,168,.18)';
    en.style.color = 'rgba(208,182,168,.9)';
    zh.style.background = 'none';
    zh.style.color = 'rgba(208,182,168,.5)';
  }
}

// ── 价格表逻辑 ──
let pricingSource = 'bazi';
function openPricing(source){
  pricingSource = source || 'bazi';
  goTo('pricing');
}
function closePricing(){
  if(pricingSource === 'oracle') goTo('oracle-result');
  else goTo('calibration');
}
let baziUnlocked = false;
let oracleUnlocked = false;

function selectPrice(){
  if(pricingSource === 'oracle'){
    oracleUnlocked = true;
    goTo('oracle-result');
    // 移除奇门蒙版
    setTimeout(()=>{
      const overlay = document.getElementById('oracle-lock-overlay');
      const blurred = document.getElementById('oracle-blurred-text');
      if(overlay) overlay.style.display='none';
      if(blurred){
        blurred.style.filter='none';
        blurred.style.color='#3a2a1a';
        blurred.style.userSelect='auto';
        blurred.style.pointerEvents='auto';
      }
      // 移除标题的🔒
      document.querySelectorAll('#page-oracle-result .result-card-inner').forEach(el=>{
        el.querySelectorAll('[style]').forEach(e=>{
          if(e.textContent.includes('In-depth Analysis 🔒')){
            e.textContent = 'In-depth Analysis';
          }
        });
      });
    }, 100);
  } else {
    baziUnlocked = true;
    goTo('calibration');
    // 移除八字四柱蒙版
    setTimeout(()=>{
      ['lock-career','lock-relationship','lock-wealth','lock-health'].forEach(id=>{
        const el = document.getElementById(id);
        if(el) el.innerHTML = '<div style="font-family:var(--ff-serif);font-size:11px;color:#5a3a1a;line-height:1.9;padding:8px">完整分析已解锁 ✓</div>';
      });
    }, 100);
  }
}

function selectRelInputTab(btn, label){
  document.querySelectorAll('.rel-input-tab').forEach(b=>b.classList.remove('active'));
  btn.classList.add('active');
  const el = document.getElementById('relInputLabel');
  if(el) el.textContent = label;
}

function selectRelSlide(card){
  document.querySelectorAll('.rel-slide-card').forEach(c=>c.classList.remove('active'));
  card.classList.add('active');
}

function selectRelType(btn){
  document.querySelectorAll('.rel-type-btn').forEach(b=>b.classList.remove('active'));
  btn.classList.add('active');
}

function updateOracleQuestion(val){
  const el=document.getElementById('oracleQuestion');
  if(!el)return;
  const text=val.trim();
  if(text){
    el.innerHTML=text.replace(/\n/g,'<br>');
  } else {
    el.innerHTML='Is this<br>the right path<br>for me?';
  }
}

// Init: splash is already active via HTML class
// ── Daily Check-in 动态日期 ──
(function(){
  const months=['JAN','FEB','MAR','APR','MAY','JUN','JUL','AUG','SEP','OCT','NOV','DEC'];
  const d=new Date();
  const dateStr=months[d.getMonth()]+' '+String(d.getDate()).padStart(2,'0')+', '+d.getFullYear();
  const el=document.getElementById('dailyDate');
  if(el)el.textContent=dateStr;
  const el2=document.getElementById('homeDailyDate');
  if(el2)el2.textContent=dateStr;

  // 干支计算
  const tiangan=['甲','乙','丙','丁','戊','己','庚','辛','壬','癸'];
  const dizhi=['子','丑','寅','卯','辰','巳','午','未','申','酉','戌','亥'];
  const y=d.getFullYear();
  const m=d.getMonth()+1;
  const day=d.getDate();
  // 年干支（以2024甲辰为基准）
  const yBase=2024;
  const yOff=(y-yBase+400)%10;
  const ydOff=(y-yBase+400)%12;
  const yearGz=tiangan[yOff]+dizhi[ydOff]+'年';
  // 月干支（简化）
  const mTian=['壬','癸','甲','乙','丙','丁','戊','己','庚','辛','壬','癸'];
  const mDi=['子','丑','寅','卯','辰','巳','午','未','申','酉','戌','亥'];
  const mIdx=(m+1)%12;
  const monthGz=mTian[(m-1+y*12)%10]+mDi[mIdx]+'月';
  // 日干支（以2024-01-01甲子为基准）
  const base=new Date(2024,0,1);
  const diff=Math.floor((d-base)/86400000);
  const dayGz=tiangan[((diff%10)+10)%10]+dizhi[((diff%12)+12)%12]+'日';
  const gz=document.getElementById('dailyGanzhi');
  if(gz)gz.innerHTML=yearGz+'<br>'+monthGz+'<br>'+dayGz;
  const gz2=document.getElementById('homeDailyGanzhi');
  if(gz2)gz2.innerHTML=yearGz+'<br>'+monthGz+'<br>'+dayGz;
})();
</script>
